generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // KOSONGKAN! Tidak boleh ada url di sini
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}